{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "Home",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/library/library",
			"style": {
				"navigationBarTitleText": "Library",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/vocabulary/vocabulary",
			"style": {
				"navigationBarTitleText": "Vocabulary",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/settings/settings",
			"style": {
				"navigationBarTitleText": "Settings",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/scan/RecognitionPage",
			"style": {
				"navigationBarTitleText": "",
				"navigationBarBackgroundColor": "#F8F9FA"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "Learning App",
		"navigationBarBackgroundColor": "#FFFFFF",
		"backgroundColor": "#F8F9FA"
	},
	"tabBar": {
		"color": "#9CA3AF",
		"selectedColor": "#2563EB",
		"backgroundColor": "#FFFFFF",
		"borderStyle": "white",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "Home",
				"iconPath": "static/tab-home.png",
				"selectedIconPath": "static/tab-home-active.png"
			},
			{
				"pagePath": "pages/library/library",
				"text": "Library",
				"iconPath": "static/tab-library.png",
				"selectedIconPath": "static/tab-library-active.png"
			},
			{
				"pagePath": "pages/vocabulary/vocabulary",
				"text": "Vocabulary",
				"iconPath": "static/tab-vocabulary.png",
				"selectedIconPath": "static/tab-vocabulary-active.png"
			},
			{
				"pagePath": "pages/settings/settings",
				"text": "Settings",
				"iconPath": "static/tab-settings.png",
				"selectedIconPath": "static/tab-settings-active.png"
			}
		]
	},
	"uniIdRouter": {}
}
